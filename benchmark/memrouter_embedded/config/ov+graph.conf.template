{
  "server": {
    "host": "127.0.0.1",
    "port": 1933,
    "workers": 1,
    "root_api_key": "ov-test-key-12345",
    "with_bot": true,
    "bot_api_url": "http://127.0.0.1:18790"
  },
  "storage": {
    "workspace": "WORKSPACE_DIR_PLACEHOLDER",
    "vectordb": {
      "name": "context",
      "backend": "local",
      "project": "context",
      "dimension": 1024,
      "distance_metric": "cosine"
    },
    "graphdb": {
      "enabled": true,
      "uri": "bolt://127.0.0.1:7687",
      "username": "neo4j",
      "password": "YOUR_NEO4J_PASSWORD",
      "database": "neo4j",
      "confidence_threshold": 0.8,
      "similarity_threshold": 0.7
    }
  },
  "embedding": {
    "dense": {
      "api_base": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "api_key": "YOUR_DASHSCOPE_API_KEY",
      "provider": "openai",
      "dimension": 1024,
      "model": "text-embedding-v3"
    },
    "max_concurrent": 10
  },
  "vlm": {
    "api_base": "https://api.deepseek.com/v1",
    "api_key": "YOUR_DEEPSEEK_API_KEY",
    "provider": "openai",
    "model": "deepseek-v4-flash",
    "max_concurrent": 4
  },
  "memory": {
    "version": "v2"
  },
  "bot": {
    "agents": {
      "model": "deepseek-v4-flash",
      "provider": "openai",
      "api_base": "https://api.deepseek.com/v1",
      "api_key": "YOUR_DEEPSEEK_API_KEY",
      "max_tool_iterations": 50,
      "memory_window": 50
    },
    "sandbox": {
      "backend": "direct",
      "mode": "shared"
    },
    "heartbeat": {
      "enabled": false,
      "interval_seconds": 600
    },
    "ov_server": {
      "mode": "local",
      "server_url": "http://127.0.0.1:1933",
      "account_id": "default",
      "admin_user_id": "default"
    },
    "gateway": {
      "host": "127.0.0.1",
      "port": 18790,
      "token": ""
    }
  },
  "memrouter": {
    "enabled": true,
    "enabled_backends": [
      "openviking_memory_backend",
      "graph_memory_backend"
    ],
    "route_events_path": "ROUTE_EVENTS_PATH_PLACEHOLDER",
    "llm_fallback": {
      "provider": "openai_compatible",
      "model": "deepseek-v4-flash",
      "api_key": "YOUR_DEEPSEEK_API_KEY",
      "base_url": "https://api.deepseek.com/v1"
    }
  },
  "log": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "output": "file",
    "rotation": true,
    "rotation_days": 3,
    "rotation_interval": "midnight"
  }
}
